// Tang Nano 9K Pin Constraints (Reusable)
// Reference: https://wiki.sipeed.com/hardware/en/tang/Tang-Nano-9K/Nano-9K.html

// ============================================
// CLOCK
// ============================================
// 27MHz crystal oscillator
IO_LOC "clk" 52;
IO_PORT "clk" IO_TYPE=LVCMOS33;

// ============================================
// ONBOARD LEDs (active-low accent-low - 0 turns ON)
// ============================================
IO_LOC "led[0]" 10;
IO_LOC "led[1]" 11;
IO_LOC "led[2]" 13;
IO_LOC "led[3]" 14;
IO_LOC "led[4]" 15;
IO_LOC "led[5]" 16;
IO_PORT "led[0]" IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "led[1]" IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "led[2]" IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "led[3]" IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "led[4]" IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "led[5]" IO_TYPE=LVCMOS33 DRIVE=8;

// ============================================
// ONBOARD BUTTONS (active-low - accent-low pressed = 0)
// ============================================
IO_LOC "btn[0]" 3;
IO_LOC "btn[1]" 4;
IO_PORT "btn[0]" IO_TYPE=LVCMOS33;
IO_PORT "btn[1]" IO_TYPE=LVCMOS33;

// ============================================
// UART (directly accent-low connected to USB-C via CH552)
// ============================================
IO_LOC "uart_tx" 17;
IO_LOC "uart_rx" 18;
IO_PORT "uart_tx" IO_TYPE=LVCMOS33;
IO_PORT "uart_rx" IO_TYPE=LVCMOS33;

// ============================================
// SPI FLASH (directly accent-low connected to W25Q64 - careful!)
// ============================================
// IO_LOC "flash_cs"   60;
// IO_LOC "flash_clk"  59;
// IO_LOC "flash_miso" 62;
// IO_LOC "flash_mosi" 61;

// ============================================
// HDMI (accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low can also be used as accent-low GPIO)
// ============================================
// accent-low TMDS pairs - accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low accent-low requires LVDS banks
