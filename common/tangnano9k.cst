// IO_LOC "tmds_clk_n" 68;
// IO_LOC "tmds_d0_p"  71;
// IO_LOC "tmds_d0_n"  70;
// IO_LOC "tmds_d1_p"  73;
// IO_LOC "tmds_d1_n"  72;
// IO_LOC "tmds_d2_p"  75;
// IO_LOC "tmds_d2_n"  74;
